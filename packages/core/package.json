{
  "name": "@cascet/core",
  "version": "0.1.0",
  "description": "Shared types, config schema and constants for CasCet — the paid-MCP gateway on Casper",
  "type": "module",
  "license": "Apache-2.0",
  "homepage": "https://cascet.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mericcintosun/CasCet.git",
    "directory": "packages/core"
  },
  "keywords": ["mcp", "x402", "casper", "micropayments", "ai-agents", "cep-18"],
  "engines": { "node": ">=20" },
  "publishConfig": { "access": "public" },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "zod": "^3.24.0"
  }
}
