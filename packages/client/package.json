{
  "name": "@cascet/client",
  "version": "0.1.0",
  "description": "CasCet buyer-side client — lets any MCP host or agent pay x402 micropayments on Casper, with budgets and cascading payment support",
  "type": "module",
  "license": "Apache-2.0",
  "homepage": "https://cascet.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mericcintosun/CasCet.git",
    "directory": "packages/client"
  },
  "keywords": ["mcp", "x402", "casper", "micropayments", "ai-agents"],
  "engines": { "node": ">=20" },
  "publishConfig": { "access": "public" },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@cascet/core": "workspace:*",
    "@make-software/casper-x402": "^1.0.0",
    "@x402/core": "^2.17.0",
    "@x402/fetch": "^2.17.0",
    "casper-js-sdk": "^5.0.12"
  }
}
