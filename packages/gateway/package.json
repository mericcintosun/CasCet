{
  "name": "@cascet/gateway",
  "version": "0.1.0",
  "description": "CasCet gateway — wrap any MCP server and charge x402 micropayments per tool call, settled on Casper",
  "type": "module",
  "license": "Apache-2.0",
  "homepage": "https://cascet.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mericcintosun/CasCet.git",
    "directory": "packages/gateway"
  },
  "keywords": ["mcp", "x402", "casper", "micropayments", "ai-agents", "gateway"],
  "engines": { "node": ">=20" },
  "publishConfig": { "access": "public" },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/bin.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@cascet/core": "workspace:*",
    "@make-software/casper-x402": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@x402/core": "^2.17.0",
    "casper-js-sdk": "^5.0.12",
    "express": "^5.1.0",
    "uuid": "^11.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0"
  }
}
