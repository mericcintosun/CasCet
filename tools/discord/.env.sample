# Copy to .env (gitignored) and fill in.
#
# 1) Discord Developer Portal -> New Application -> Bot -> Reset Token -> copy.
DISCORD_BOT_TOKEN=

# 2) The CasCet server (guild) ID. In Discord: User Settings -> Advanced ->
#    Developer Mode ON, then right-click the server icon -> Copy Server ID.
GUILD_ID=

# --- optional ---
# Demo Day scheduled event start (ISO 8601, UTC). Defaults to Buildathon demo day.
# DEMO_DAY_ISO=2026-07-26T16:00:00.000Z

# Set to 1 to print the plan without writing anything to Discord.
# DRY_RUN=1
