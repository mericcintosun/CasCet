# CasCet contracts — Casper Testnet deploy config (odra livenet backend).
# Copy to `.env` and fill in, then:
#   cargo run --bin cascet_contracts_cli -- deploy

# Path to the deployer's PEM secret key (the funded testnet account).
ODRA_CASPER_LIVENET_SECRET_KEY_PATH=./keys/deployer_secret_key.pem

# Casper Testnet JSON-RPC node endpoint.
ODRA_CASPER_LIVENET_NODE_ADDRESS=https://node.testnet.cspr.cloud/rpc

# Testnet chain name (do not change for testnet).
ODRA_CASPER_LIVENET_CHAIN_NAME=casper-test
